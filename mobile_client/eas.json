{
  "cli": {
    "version": ">= 18.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "latest"
      },
      "android": {
        "image": "latest",
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "image": "latest"
      }
    },
    "enterprise": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "latest",
        "enterpriseProvisioning": "universal"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
