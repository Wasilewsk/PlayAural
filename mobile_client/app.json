{
  "expo": {
    "name": "PlayAural Mobile",
    "slug": "playaural-mobile",
    "version": "1.0.4.4",
    "newArchEnabled": false,
    "orientation": "portrait",
    "assetBundlePatterns": [
      "sounds/**/*"
    ],
    "android": {
      "package": "one.ddt.playaural.mobile",
      "versionCode": 10404,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "ios": {
      "bundleIdentifier": "one.ddt.playaural.mobile",
      "bitcode": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-asset",
      [
        "@livekit/react-native-expo-plugin",
        {
          "android": {
            "audioType": "media"
          },
          "ios": {
            "enableMultitaskingCameraAccess": false
          }
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for table voice chat."
        }
      ],
      "./plugins/withPlayAuralBackgroundService",
      "expo-audio",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "7cd5f552-9e02-4f92-aafa-dbdcbca8141a"
      }
    },
    "owner": "jjjjjkhf"
  }
}
